# ============================================================
# AskMyDocs — 环境变量配置示例
# 使用方法：cp .env.example .env  然后填写实际值
# ============================================================

# ─── 数据库 ───────────────────────────────────────────────
# PostgreSQL 连接字符串（使用 Docker Compose 默认值时无需修改）
DATABASE_URL=postgresql://${POSTGRES_USER:-ai_user}:${POSTGRES_PASSWORD:-ai_password}@postgres:5432/${POSTGRES_DB:-ai_assistant}

# PostgreSQL 单独配置（用于 docker-compose.yml）
POSTGRES_USER=ai_user
POSTGRES_PASSWORD=change_me_secure_password
POSTGRES_DB=ai_assistant

# ─── Redis ────────────────────────────────────────────────
# Redis 连接字符串（使用 Docker Compose 默认值时无需修改）
REDIS_URL=redis://redis:6379/0

# ─── LLM（OpenAI 兼容接口）───────────────────────────────
# API 基础 URL（阿里百炼示例，可替换为任意 OpenAI 兼容服务）
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 你的 API Key
LLM_API_KEY=your-llm-api-key-here
# 使用的模型 ID
LLM_MODEL=qwen-plus

# ─── Embedding ────────────────────────────────────────────
# Embedding 服务基础 URL
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Embedding API Key（可与 LLM_API_KEY 相同）
EMBEDDING_API_KEY=your-embedding-api-key-here
# Embedding 模型 ID
EMBEDDING_MODEL=text-embedding-v3

# ─── 语音服务（阿里百炼）─────────────────────────────────
# DashScope API Key（STT / TTS 使用，通常与上方相同）
DASHSCOPE_API_KEY=your-dashscope-api-key-here
# 语音识别（STT）模型
STT_MODEL=qwen3-asr-flash-2026-02-10
# 语音合成（TTS）模型
TTS_MODEL=cosyvoice-v3-flash
# TTS 音色（可选：longanyang / longhua / longxiang 等）
TTS_VOICE=longanyang

# ─── JWT 鉴权 ─────────────────────────────────────────────
# ⚠️  务必修改为随机字符串，生产环境绝对不能使用默认值
# 生成命令：openssl rand -hex 32
JWT_SECRET=change-me-use-openssl-rand-hex-32
# Token 有效期（天）
JWT_EXPIRE_DAYS=7

# ─── 限流 ─────────────────────────────────────────────────
# 每用户每分钟最大请求次数
RATE_LIMIT_PER_MINUTE=30

# ─── Chroma 向量数据库 ────────────────────────────────────
# 使用 Docker Compose 默认值时无需修改（容器内端口为 8000）
CHROMA_HOST=chroma
CHROMA_PORT=8000

# ─── 文件存储 ─────────────────────────────────────────────
# 上传文件保存路径（容器内路径，已通过 volume 映射到 ./data/files）
FILE_STORAGE_PATH=/data/files

# ─── CORS ─────────────────────────────────────────────────
# 允许的前端域名，多个域名用英文逗号分隔
# 开发环境示例：http://localhost:3000
# 生产环境示例：https://your-domain.com
CORS_ORIGINS=http://localhost:3000

# ─── Email（SMTP）──────────────────────────────────────────
# SMTP 服务器地址（留空则邮件打印到日志，如 SendGrid/AWS SES/QQ邮箱等）
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM_ADDRESS=noreply@askmydocs.com
EMAIL_USE_TLS=true
